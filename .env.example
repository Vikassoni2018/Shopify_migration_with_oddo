# Copy this file to .env for local development.
NODE_ENV=development
HOST=0.0.0.0
PORT=3456
APP_NAME=Shopify Migration with Odoo

# Local browser/API defaults
LOCAL_API_BASE_URL=http://127.0.0.1:3456
DEFAULT_API_BASE_URL=http://127.0.0.1:3456

# Local public URL
PUBLIC_BASE_URL=http://127.0.0.1:3456

# Render production URL is set in render.yaml:
# https://shopify-migration-with-oddo.onrender.com

# Import defaults
DEFAULT_TIMEZONE_OFFSET=+08:00

# Admin login for /admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
APP_SESSION_SECRET=replace-with-a-long-random-secret

# Optional Stripe configuration
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
